{
    "license": "MIT",
    "type": "library",
    "name": "math3usmartins/php-minibus",
    "description": "Minibus is a message bus created for legacy systems in PHP where modern implementations are not supported.",
    "autoload": {
        "psr-4": {
            "MiniBus\\": "src",
            "MiniBus\\Test\\": "test"
        }
    },
    "require": {
        "php": "^7.0"
    },
    "suggest": {
        "ext-json": "*",
        "ext-pcntl": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^6.5",
        "phpunit/php-code-coverage": "^5.3",
        "friendsofphp/php-cs-fixer": "^2.19",
        "phpstan/phpstan": "^0.9.3"
    }
}
