{
    "license": "MIT",
    "type": "library",
    "name": "math3usmartins/php-minibus",
    "description": "Minibus is a message bus created for legacy systems in PHP where modern implementations are not supported.",
    "autoload": {
        "psr-4": {
            "MiniBus\\": "src",
            "MiniBus\\Test\\": "test"
        }
    },
    "require": {
        "php": "^8.0"
    },
    "suggest": {
        "ext-json": "*",
        "ext-pcntl": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "phpunit/php-code-coverage": "^9.2",
        "friendsofphp/php-cs-fixer": "^3.37",
        "phpstan/phpstan": "^1.10",
        "rector/rector": "^0.18.6"
    }
}
